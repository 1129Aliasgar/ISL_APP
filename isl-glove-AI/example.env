PORT=5000
NODE_ENV=development
# Node on host:
MONGO_URI=mongodb://127.0.0.1:27017/isl_glove
# Backend in Docker Desktop with Mongo on host (see docker-compose.local.yml default):
# MONGO_URI=mongodb://host.docker.internal:27017/isl_glove
MODEL_PATH=ml/model.tflite
PYTHON_PATH=python
JWT_SECRET=replace-with-strong-secret
DEVICE_TOKEN=local-dev-device-token
PUBLIC_BASE_URL=https://burthensome-emerald-libidinally.ngrok-free.dev